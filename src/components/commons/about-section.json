{
  "collectionName": "components_commons_about_sections",
  "info": {
    "displayName": "About Us Section",
    "description": "Home 'About us' section: title, subtitle, description, image gallery, years-in-business counter and the highlighted stat items."
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "subtitle": {
      "type": "text"
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "stats": {
      "type": "component",
      "repeatable": true,
      "component": "commons.stat-item"
    },
    "yearsInBusiness": {
      "type": "integer"
    }
  }
}
